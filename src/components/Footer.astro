---
import site from "../data/site.json";
import links from "../data/links.json";

const website = links.find((item) => item.id === "website");
const email = links.find((item) => item.id === "email");
---

<footer class="footer">
  <div class="container footer-grid">
    <div>
      <p class="eyebrow">XUAN Spatial Perception</p>
      <h2>让空间重新被感受到</h2>
    </div>
    <div class="meta">
      <p>{site.brand.tagline}</p>
      <p>{site.brand.taglineEn}</p>
      {website && <p>Website: <a href={website.href}>{website.value}</a></p>}
      {email?.value && <p>Email: <a href={email.href}>{email.value}</a></p>}
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--line);
    padding: 48px 0;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr minmax(240px, 0.5fr);
    gap: 32px;
  }

  h2 {
    margin: 10px 0 0;
    font-size: clamp(30px, 5vw, 62px);
    line-height: 1.05;
    font-weight: 560;
  }

  p {
    margin: 0 0 8px;
  }

  a {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  @media (max-width: 700px) {
    .footer-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
