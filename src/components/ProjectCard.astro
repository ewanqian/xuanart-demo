---
const { project, compact = false } = Astro.props;

const searchText = [
  project.title,
  project.titleEn,
  project.category,
  project.type,
  project.role,
  project.clientOrContext,
  project.oneLiner,
  ...(project.keywords ?? []),
  ...(project.credits ?? []).map((credit) => `${credit.role} ${credit.name}`),
]
  .join(" ")
  .toLowerCase();
---

<a class:list={["project-card", { compact }]} href={`/projects/${project.slug}`} data-project-card data-search={searchText}>
  {project.cover && (
    <figure class="cover">
      <img src={project.cover} alt={`${project.title} project cover`} />
    </figure>
  )}
  <div class="card-body">
    <div class="card-top">
      <span>{project.category}</span>
      <span>{project.year}</span>
    </div>
    <h3>{project.title}</h3>
    <p class="en">{project.titleEn}</p>
    <p>{project.oneLiner}</p>
    <div class="tag-list">
      {project.keywords.slice(0, 3).map((tag) => <span class="tag">{tag}</span>)}
    </div>
  </div>
</a>

<style>
  .project-card {
    display: flex;
    min-height: 360px;
    flex-direction: column;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.62);
    overflow: hidden;
    transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
  }

  .project-card:hover {
    transform: translateY(-4px);
    border-color: rgba(80, 108, 143, 0.45);
    background: rgba(255, 255, 255, 0.86);
  }

  .project-card.compact {
    min-height: 330px;
  }

  .cover {
    aspect-ratio: 16 / 9.3;
    margin: 0;
    background: rgba(23, 29, 38, 0.08);
    overflow: hidden;
  }

  .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: 18px;
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    color: var(--blue);
    font-size: 12px;
    line-height: 1.4;
  }

  h3 {
    margin: 24px 0 8px;
    font-size: clamp(19px, 2.1vw, 27px);
    line-height: 1.18;
    font-weight: 560;
  }

  p {
    margin: 0;
    color: var(--muted);
    font-size: 15px;
    line-height: 1.86;
  }

  .en {
    margin-bottom: 18px;
    color: var(--ink);
    font-size: 13px;
  }

  .tag-list {
    margin-top: auto;
    padding-top: 16px;
  }
</style>
