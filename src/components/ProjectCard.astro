---
const { project, compact = false } = Astro.props;
---

<a class:list={["project-card", { compact }]} href={`/projects/${project.slug}`}>
  <div class="card-top">
    <span>{project.category}</span>
    <span>{project.year}</span>
  </div>
  <h3>{project.title}</h3>
  <p class="en">{project.titleEn}</p>
  <p>{project.oneLiner}</p>
  <div class="tag-list">
    {project.keywords.slice(0, 3).map((tag) => <span class="tag">{tag}</span>)}
  </div>
</a>

<style>
  .project-card {
    display: flex;
    min-height: 260px;
    flex-direction: column;
    justify-content: space-between;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 22px;
    background: rgba(255, 255, 255, 0.62);
    transition: transform 180ms ease, border-color 180ms ease, background 180ms ease;
  }

  .project-card:hover {
    transform: translateY(-4px);
    border-color: rgba(80, 108, 143, 0.45);
    background: rgba(255, 255, 255, 0.86);
  }

  .project-card.compact {
    min-height: 220px;
  }

  .card-top {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    color: var(--blue);
    font-size: 12px;
    line-height: 1.4;
  }

  h3 {
    margin: 34px 0 8px;
    font-size: clamp(21px, 2.4vw, 30px);
    line-height: 1.18;
    font-weight: 560;
  }

  p {
    margin: 0;
    color: var(--muted);
    font-size: 15px;
    line-height: 1.86;
  }

  .en {
    margin-bottom: 18px;
    color: var(--ink);
    font-size: 13px;
  }
</style>
