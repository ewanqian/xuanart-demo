---
const { members = [] } = Astro.props;
---

<div class="team-grid">
  {members.map((member) => (
    <article class="member-card">
      {member.avatar ? (
        <img src={member.avatar} alt={`${member.name} portrait`} loading="lazy" />
      ) : (
        <div class="avatar-placeholder" aria-hidden="true">{member.name.slice(0, 1)}</div>
      )}
      <div>
        <h3>{member.name}</h3>
        <p class="role">{member.role}</p>
        {member.bio && <p>{member.bio}</p>}
      </div>
    </article>
  ))}
</div>

<style>
  .team-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
    margin-top: 32px;
  }

  .member-card {
    display: flex;
    min-width: 0;
    flex-direction: column;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.62);
    overflow: hidden;
  }

  .member-card:first-child {
    grid-column: span 2;
    grid-row: span 2;
    background: rgba(255, 255, 255, 0.58);
  }

  img,
  .avatar-placeholder {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    background:
      linear-gradient(135deg, rgba(49, 95, 214, 0.12), rgba(255, 240, 105, 0.16)),
      rgba(255, 255, 255, 0.72);
  }

  .avatar-placeholder {
    display: grid;
    place-items: center;
    color: var(--blue);
    font-size: 34px;
    font-weight: 560;
  }

  .member-card > div {
    padding: 14px;
  }

  h3 {
    margin: 0 0 6px;
    font-size: clamp(16px, 1.8vw, 20px);
    line-height: 1.2;
    font-weight: 560;
  }

  p {
    margin: 0;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.78;
  }

  .role {
    margin-bottom: 10px;
    color: var(--blue);
    font-size: 11px;
    line-height: 1.35;
    text-transform: uppercase;
  }

  @media (max-width: 860px) {
    .team-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .member-card:first-child {
      grid-column: span 2;
      grid-row: auto;
    }
  }
</style>
