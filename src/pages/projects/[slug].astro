---
import Layout from "../../components/Layout.astro";
import projects from "../../data/projects.json";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const gallery = project.gallery ?? [];
const credits = project.credits ?? [];
---

<Layout title={`${project.title} | XUAN Spatial Perception`}>
  <article>
    <section class="project-hero">
      <div class="container two-col">
        <div>
          <p class="eyebrow">{project.category}</p>
          <h1>{project.title}</h1>
          <p class="lead">{project.titleEn}</p>
        </div>
        <aside class="thin-card">
          <dl>
            <div><dt>Year</dt><dd>{project.year}</dd></div>
            <div><dt>Type</dt><dd>{project.type}</dd></div>
            <div><dt>Role</dt><dd>{project.role}</dd></div>
            <div><dt>Context</dt><dd>{project.clientOrContext}</dd></div>
          </dl>
        </aside>
      </div>
      {project.cover && (
        <figure class="project-cover">
          <img src={project.cover} alt={`${project.title} cover`} />
        </figure>
      )}
    </section>

    <section class="section">
      <div class="container two-col">
        <div>
          <p class="eyebrow">Summary</p>
          <h2 class="section-title">{project.oneLiner}</h2>
        </div>
        <div>
          <p class="body">{project.description}</p>
          <div class="tag-list">
            {project.keywords.map((tag) => <span class="tag">{tag}</span>)}
          </div>
          {credits.length > 0 && (
            <div class="credit-list">
              <p class="eyebrow">Credits</p>
              <dl>
                {credits.map((credit) => (
                  <div>
                    <dt>{credit.role}</dt>
                    <dd>{credit.name}</dd>
                  </div>
                ))}
              </dl>
            </div>
          )}
          <div class="button-row">
            <a class="button secondary" href="/projects">返回项目</a>
            <a class="button" href="/contact">预约沟通</a>
          </div>
        </div>
      </div>
    </section>

    {gallery.length > 0 && (
      <section class="section gallery-section">
        <div class="container">
          <p class="eyebrow">Gallery</p>
          <h2 class="section-title">项目图集</h2>
          <div class="gallery-grid">
            {gallery.map((image, index) => (
              <figure>
                <img src={image} alt={`${project.title} gallery ${index + 1}`} loading="lazy" />
              </figure>
            ))}
          </div>
        </div>
      </section>
    )}
  </article>
</Layout>

<style>
  .project-hero {
    padding: 94px 0 76px;
  }

  .project-cover {
    width: min(calc(100% - 32px), var(--max));
    margin: 0 auto;
    border: 1px solid var(--line);
    border-radius: 8px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.62);
  }

  .project-cover img {
    width: 100%;
    aspect-ratio: 16 / 9.3;
    object-fit: cover;
  }

  h1 {
    margin: 12px 0 20px;
    font-size: clamp(36px, 6vw, 84px);
    line-height: 1.06;
    font-weight: 560;
  }

  dl {
    margin: 0;
  }

  dl div {
    display: grid;
    grid-template-columns: 92px 1fr;
    gap: 12px;
    padding: 14px 0;
    border-bottom: 1px solid var(--line);
  }

  dl div:last-child {
    border-bottom: 0;
  }

  dt {
    color: var(--blue);
    font-size: 12px;
  }

  dd {
    margin: 0;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.5;
  }

  .body {
    margin: 0;
    color: var(--muted);
    font-size: 17px;
    line-height: 1.9;
  }

  .credit-list {
    margin-top: 32px;
  }

  .credit-list dl {
    border-top: 1px solid var(--line);
    margin-top: 14px;
  }

  .credit-list dl div {
    grid-template-columns: minmax(120px, 0.42fr) 1fr;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    margin-top: 28px;
  }

  .gallery-grid figure {
    margin: 0;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.62);
    overflow: hidden;
  }

  .gallery-grid img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  @media (max-width: 860px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
