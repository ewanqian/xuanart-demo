---
import Layout from "../../components/Layout.astro";
import projects from "../../data/projects.json";

export function getStaticPaths() {
  return projects
    .filter((project) => project.public_status === "published")
    .map((project) => ({
      params: { slug: project.slug },
      props: { project },
    }));
}

const { project } = Astro.props;
const gallery = project.gallery ?? [];
const credits = project.credits ?? [];
const mediaPreview = project.mediaPreview;
const hasMediaPreview = mediaPreview?.status === "available";
const mediaPreviewLabel = hasMediaPreview ? mediaPreview.label?.trim() || "Motion Archive" : null;
const mediaPreviewSourceNote = hasMediaPreview ? mediaPreview.sourceNote?.trim() : null;
const mediaPreviewClipCount = hasMediaPreview ? (mediaPreview.proxyClips ?? []).slice(0, 2).length : 0;
const displayYear = project.year || null;
const mediaLabel = project.media_type === "external" ? "External Media" : "Project Images";
const detailRows = [
  displayYear && ["Year", displayYear],
  ["Type", project.type],
  ["Role", project.role],
  ["Context", project.clientOrContext],
  ["Media", mediaLabel],
].filter(Boolean);
const pageTitle = project.slug === "titan-holographic-sound-forest"
  ? project.title
  : `${project.title} | XUAN Spatial Perception`;
const pageDescription = project.slug === "titan-holographic-sound-forest"
  ? project.description
  : undefined;
---

<Layout title={pageTitle} description={pageDescription}>
  <article>
    <section class="project-hero">
      <div class="container two-col">
        <div>
          <p class="eyebrow">{project.categoryGroup ?? project.category}</p>
          <h1>{project.title}</h1>
          <p class="lead">{project.title_en ?? project.titleEn}</p>
        </div>
        <aside class="thin-card">
          <dl>
            {detailRows.map(([label, value]) => (
              <div><dt>{label}</dt><dd>{value}</dd></div>
            ))}
          </dl>
        </aside>
      </div>
      {project.cover && (
        <figure class="project-cover">
          <img src={project.cover} alt={`${project.title} cover`} />
        </figure>
      )}
    </section>

    <section class="section">
      <div class="container two-col">
        <div>
          <p class="eyebrow">Summary</p>
          <h2 class="section-title">{project.oneLiner}</h2>
        </div>
        <div>
          <p class="body">{project.description}</p>
          <div class="tag-list">
            {project.keywords.map((tag) => <span class="tag">{tag}</span>)}
          </div>
          {hasMediaPreview && (
            <aside class="thin-card motion-archive" aria-labelledby="motion-archive-title">
              <div class="motion-archive-header">
                <p class="eyebrow" id="motion-archive-title">现场影像 / Motion Archive</p>
                {mediaPreviewLabel && <span class="tag">{mediaPreviewLabel}</span>}
              </div>
              {mediaPreviewSourceNote && <p class="archive-note">{mediaPreviewSourceNote}</p>}
              {mediaPreviewClipCount > 0 && (
                <ul class="archive-clips">
                  <li>
                    <span>归档片段</span>
                    已整理 {mediaPreviewClipCount} 条现场短片
                  </li>
                </ul>
              )}
            </aside>
          )}
          {(project.external_video_url || project.external_url) && (
            <div class="media-link">
              <p class="eyebrow">External Media</p>
              <a class="button secondary" href={project.external_video_url || project.external_url} target="_blank" rel="noreferrer">
                打开外部视频 / 链接
              </a>
            </div>
          )}
          {credits.length > 0 && (
            <div class="credit-list">
              <p class="eyebrow">Credits</p>
              <dl>
                {credits.map((credit) => (
                  <div>
                    <dt>{credit.role}</dt>
                    <dd>{credit.name}</dd>
                  </div>
                ))}
              </dl>
            </div>
          )}
          <div class="button-row">
            <a class="button secondary" href="/projects">返回项目</a>
            <a class="button" href="/contact">预约沟通</a>
          </div>
        </div>
      </div>
    </section>

    {gallery.length > 0 && (
      <section class="section gallery-section">
        <div class="container">
          <p class="eyebrow">Gallery</p>
          <h2 class="section-title">项目图集</h2>
          <div class="gallery-grid">
            {gallery.map((image, index) => (
              <figure>
                <img src={image} alt={`${project.title} gallery ${index + 1}`} loading="lazy" />
              </figure>
            ))}
          </div>
        </div>
      </section>
    )}
  </article>
</Layout>

<style>
  .project-hero {
    padding: 94px 0 76px;
  }

  .project-cover {
    width: min(calc(100% - 32px), var(--max));
    margin: 0 auto;
    border: 1px solid var(--line);
    border-radius: 8px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.62);
  }

  .project-cover img {
    width: 100%;
    aspect-ratio: 16 / 9.3;
    object-fit: cover;
  }

  h1 {
    margin: 12px 0 20px;
    font-size: clamp(36px, 6vw, 84px);
    line-height: 1.06;
    font-weight: 560;
  }

  dl {
    margin: 0;
  }

  dl div {
    display: grid;
    grid-template-columns: 92px 1fr;
    gap: 12px;
    padding: 14px 0;
    border-bottom: 1px solid var(--line);
  }

  dl div:last-child {
    border-bottom: 0;
  }

  dt {
    color: var(--blue);
    font-size: 12px;
  }

  dd {
    margin: 0;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.5;
  }

  .body {
    margin: 0;
    color: var(--muted);
    font-size: 17px;
    line-height: 1.9;
  }

  .credit-list {
    margin-top: 32px;
  }

  .media-link {
    margin-top: 28px;
  }

  .motion-archive {
    margin-top: 28px;
    padding: 18px;
  }

  .motion-archive-header {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
    justify-content: space-between;
  }

  .motion-archive .eyebrow {
    margin: 0;
  }

  .motion-archive .tag {
    background: rgba(245, 228, 176, 0.34);
    color: var(--blue);
  }

  .archive-note {
    margin: 14px 0 0;
    color: var(--muted);
    font-size: 14px;
    line-height: 1.8;
  }

  .archive-clips {
    display: grid;
    gap: 8px;
    margin: 16px 0 0;
    padding: 0;
    list-style: none;
  }

  .archive-clips li {
    display: grid;
    grid-template-columns: 72px minmax(0, 1fr);
    gap: 12px;
    color: var(--muted);
    font-size: 13px;
    line-height: 1.6;
    overflow-wrap: anywhere;
  }

  .archive-clips span {
    color: var(--blue);
    font-size: 12px;
  }

  .credit-list dl {
    border-top: 1px solid var(--line);
    margin-top: 14px;
  }

  .credit-list dl div {
    grid-template-columns: minmax(120px, 0.42fr) 1fr;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
    margin-top: 28px;
  }

  .gallery-grid figure {
    margin: 0;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.62);
    overflow: hidden;
  }

  .gallery-grid img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
  }

  @media (max-width: 860px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
