---
import Layout from "../components/Layout.astro";
import links from "../data/links.json";

const visibleLinks = links.filter((item) => item.value);
const socialQr = links.filter((item) => item.qr);
---

<Layout title="联系 | XUAN Spatial Perception">
  <section class="page-hero">
    <div class="container two-col">
      <div>
        <p class="eyebrow">Contact</p>
        <h1>商务合作 / 预约项目沟通</h1>
        <p class="lead">Business Inquiries / Schedule a Project Conversation</p>
        <div class="button-row">
          <a class="button" href="/projects">View Portfolio</a>
          <a class="button secondary" href="/about">About XUAN</a>
        </div>
      </div>
      <div class="contact-card">
        {visibleLinks.map((item) => (
          <div class="contact-row">
            <span>{item.label}</span>
            {item.href ? (
              <a href={item.href} target={item.href.startsWith("http") ? "_blank" : undefined} rel={item.href.startsWith("http") ? "noreferrer" : undefined}>
                {item.value}
              </a>
            ) : (
              <strong>{item.value}</strong>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  {socialQr.length > 0 && (
    <section class="section">
      <div class="container two-col">
        <div>
          <p class="eyebrow">QR / Social</p>
          <h2 class="section-title">社交平台入口</h2>
        </div>
        <div class="qr-grid">
          {socialQr.map((item) => (
            <article class="qr-card">
              <img src={item.qr} alt={`${item.label} QR`} loading="lazy" />
              <p>{item.label}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}
</Layout>

<style>
  .page-hero {
    min-height: 72vh;
    display: grid;
    align-items: center;
    padding: 76px 0;
  }

  h1 {
    margin: 12px 0 0;
    font-size: clamp(30px, 4.1vw, 52px);
    line-height: 1.22;
    font-weight: 560;
    word-break: keep-all;
  }

  .contact-card {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.64);
    overflow: hidden;
  }

  .contact-row {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 18px;
    padding: 18px;
    border-bottom: 1px solid var(--line);
  }

  .contact-row:last-child {
    border-bottom: 0;
  }

  span {
    color: var(--blue);
    font-size: 12px;
    text-transform: uppercase;
  }

  strong,
  .contact-row a {
    font-size: 16px;
    line-height: 1.45;
    font-weight: 520;
    overflow-wrap: anywhere;
  }

  .contact-row a {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .qr-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 14px;
  }

  .qr-card {
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 14px;
    background: rgba(255, 255, 255, 0.58);
  }

  .qr-card img {
    width: 100%;
    aspect-ratio: 1;
    border: 1px solid var(--line);
    border-radius: 8px;
  }

  .qr-card p {
    margin: 12px 0 0;
    color: var(--muted);
    font-size: 13px;
    line-height: 1.5;
  }

  @media (max-width: 560px) {
    .contact-row,
    .qr-grid {
      grid-template-columns: 1fr;
    }

    .contact-row {
      gap: 8px;
    }
  }
</style>
