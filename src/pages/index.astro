const buildConceptRow = (offset = 0) =>
  Array.from({ length: 10 }, (_, index) => {
    const slide = conceptSlides[(index + offset) % conceptSlides.length];
    const media = conceptImagePool[(index + offset) % conceptImagePool.length];
    const nextMedia = conceptImagePool[(index + offset + 3) % conceptImagePool.length];
    if (index % 3 === 1) {
      return {
        type: "word",
        text: conceptWallWords[(index + offset) % conceptWallWords.length],
        label: slide.subtitle,
        bg: media.src,
      };
    }
    if (index % 3 === 2) {
      return {
        type: "phrase",
        text: slide.title,
        label: slide.label,
        bg: nextMedia.src,
      };
    }
    return {
      type: "image",
      src: media.src,
      title: media.title,
      label: media.label,
    };
  });

const conceptWallRows = [
  { duration: 156, delay: -8, reverse: false, tiles: buildConceptRow(0) },
  { duration: 174, delay: -44, reverse: true, tiles: buildConceptRow(5) },
  { duration: 164, delay: -25, reverse: false, tiles: buildConceptRow(10) },
];

const buildProjectRow = (offset = 0) =>
