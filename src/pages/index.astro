---

<Layout title="XUAN Spatial Perception｜轩空间感知">
  <section class="concept-guide" data-concept-guide aria-label="XUAN Spatial Perception concept guide">
    <div class="concept-bg" aria-hidden="true"></div>
    <div class="container concept-inner">
      <div class="concept-copy">
        <p class="eyebrow">XUAN Spatial Perception</p>
        <h1>
          <span>{site.brand.name}</span>
          <span>让空间重新被感受到</span>
        </h1>
        <p class="concept-lead">
          <span>空间为画布，光影即颜料。</span>
          <span>City to Nature / Past to Future / Digital to Real.</span>
        </p>
      </div>

      <div class="concept-stage">
        <div class="concept-mosaic" aria-hidden="true">
          {conceptWallRows.map((row) => (
            <div
              class:list={["mosaic-row", { "is-reverse": row.reverse }]}
              style={`--duration:${row.duration}s; --delay:${row.delay}s;`}
            >
              <div class="mosaic-track">
                {row.tiles.concat(row.tiles).map((tile, index) => (
	                  tile.type === "image" ? (
	                    <figure class="mosaic-tile image-tile">
	                      <picture>
	                        {tile.motion ? <source srcset={tile.motion} type="image/avif" /> : null}
	                        <img src={tile.src} alt="" loading={index < 8 ? "eager" : "lazy"} />
	                      </picture>
                      <figcaption>
                        <span>{tile.title}</span>
                        <small>{tile.label}</small>
                      </figcaption>
                    </figure>
	                  ) : (
	                    <div class:list={["mosaic-tile", tile.type === "phrase" ? "phrase-tile" : "word-tile"]}>
	                      <picture class="tile-bg" aria-hidden="true">
	                        {tile.motion ? <source srcset={tile.motion} type="image/avif" /> : null}
	                        <img src={tile.bg} alt="" loading={index < 8 ? "eager" : "lazy"} />
	                      </picture>
                      <span>{tile.text}</span>
                      <small>{tile.label}</small>
                    </div>
                  )
                ))}
              </div>
            </div>
          ))}
        </div>

        <div class="concept-atmosphere-copy" aria-hidden="true">
          <span>EXHIBITION WALL LOOP</span>
          <strong>图像 / 词语 / 路径 / 记忆</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="billboard" data-billboard aria-label="XUAN project media billboard">
    <div class="billboard-stage" aria-hidden="true">
      {billboardSlides.map((slide, index) => (
        <figure class:list={["billboard-slide", { "is-active": index === 0 }]} data-slide data-index={index}>
          {slide.video ? (
            <video
              src={slide.video}
              poster={slide.poster}
              muted
              loop
              playsinline
              preload={index < 2 ? "auto" : "metadata"}
            />
          ) : (
            <img src={slide.poster} alt="" loading={index < 2 ? "eager" : "lazy"} />
          )}
        </figure>
      ))}
    </div>

    <div class="billboard-wash" aria-hidden="true"></div>

    <div class="container billboard-inner">
      <div class="billboard-copy">
        <p class="eyebrow">Tzone / 图域主线</p>
        <h2>
          <span>代表项目</span>
          <span>文旅、展陈、品牌空间</span>
        </h2>
        <p class="billboard-line">以成熟项目呈现空间感知方法。</p>
      </div>

      <div class="billboard-panel">
        <div class="panel-head">
          <span>自动播放</span>
          <span>PV LOOP</span>
        </div>
        <div class="active-copy" aria-live="polite">
          {billboardSlides.map((slide, index) => (
            <article class:list={["active-item", { "is-active": index === 0 }]} data-copy data-index={index}>
              <p>{slide.category}</p>
              <h3>{slide.cue}</h3>
              <span>{slide.title} / {slide.titleEn}</span>
              <small>{slide.line}</small>
            </article>
          ))}
        </div>
        <div class="progress" aria-hidden="true"><span></span></div>
      </div>

      <nav class="cue-rail" aria-label="Loop scenes">
        {billboardSlides.map((slide, index) => (
          <button class:list={["cue-button", { "is-active": index === 0 }]} type="button" data-cue data-index={index}>
            <img src={slide.poster} alt="" loading={index < 4 ? "eager" : "lazy"} />
            <span>{slide.title}</span>
          </button>
        ))}
      </nav>
    </div>
  </section>

  <section class="project-strip" aria-label="Selected project entrances">
    <div class="container">
      <div class="strip-head">
        <p class="eyebrow">Selected Works</p>
        <a class="button secondary" href="/projects">全部项目</a>
      </div>
      <div class="project-motion-wall" aria-label="Project motion wall">
        {projectWallRows.map((row) => (
          <div
            class:list={["project-motion-row", { "is-reverse": row.reverse }]}
            style={`--duration:${row.duration}s; --delay:${row.delay}s;`}
          >
            <div class="project-motion-track">
              {row.tiles.concat(row.tiles).map((tile, index) => (
                <a class="project-motion-tile" href="/projects">
                  <picture>
                    <source srcset={tile.motion} type="image/avif" />
                    <img src={tile.src} alt="" loading={index < 6 ? "eager" : "lazy"} />
                  </picture>
                  <span>{tile.title}</span>
                  <small>{tile.label}</small>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
      <div class="focus-grid">
        {focusWorks.map((work) => (
          <a class="focus-card" href={work.href}>
            <img src={work.poster} alt={`${work.title} preview`} loading="lazy" />
            <div>
              <span>{work.category}</span>
              <h2>{work.title}</h2>
              <p>{work.cue}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  const setupBillboard = () => {
    const root = document.querySelector("[data-billboard]");
    if (!root) return;
    const slides = Array.from(root.querySelectorAll("[data-slide]"));
    const copies = Array.from(root.querySelectorAll("[data-copy]"));
    const cues = Array.from(root.querySelectorAll("[data-cue]"));
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let active = 0;
    let timer = null;
    const duration = 5200;

    const setActive = (next) => {
      active = (next + slides.length) % slides.length;
      slides.forEach((slide, index) => {
        const video = slide.querySelector("video");
        const isActive = index === active;
        slide.classList.toggle("is-active", isActive);
        copies[index]?.classList.toggle("is-active", isActive);
        cues[index]?.classList.toggle("is-active", isActive);
        if (!video) return;
        if (isActive && !reduceMotion) {
          video.currentTime = Math.min(video.currentTime, 0.2);
          video.play().catch(() => {});
        } else {
          video.pause();
        }
      });
    };

    const start = () => {
      if (reduceMotion || timer) return;
      timer = window.setInterval(() => setActive(active + 1), duration);
    };

    cues.forEach((button) => {
      button.addEventListener("click", () => {
        if (timer) {
          window.clearInterval(timer);
          timer = null;
        }
        setActive(Number(button.dataset.index || 0));
        start();
      });
    });

    document.addEventListener("visibilitychange", () => {
      if (document.hidden) {
        if (timer) window.clearInterval(timer);
        timer = null;
        slides.forEach((slide) => slide.querySelector("video")?.pause());
      } else {
        setActive(active);
        start();
      }
    });

    setActive(0);
    start();
  };

  setupBillboard();
</script>

<style>
  .concept-guide {
    position: relative;
    min-height: calc(100svh - 74px);
    overflow: hidden;
    background: #f4efe3;
    color: var(--ink);
    isolation: isolate;
  }

  .concept-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 16% 20%, rgba(255, 240, 105, 0.26), transparent 22rem),
      radial-gradient(circle at 86% 18%, rgba(49, 95, 214, 0.13), transparent 24rem),
      linear-gradient(90deg, rgba(49, 95, 214, 0.05) 1px, transparent 1px) 0 0 / 90px 90px,
      linear-gradient(0deg, rgba(49, 95, 214, 0.035) 1px, transparent 1px) 0 0 / 90px 90px;
  }

  .concept-inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-rows: auto auto;
    gap: 24px;
    padding: 34px 0 28px;
  }

  .concept-copy {
    display: grid;
    grid-template-columns: minmax(260px, 0.75fr) minmax(280px, 0.55fr);
    gap: 32px;
    align-items: end;
  }

  .concept-copy .eyebrow,
  .concept-copy h1 {
    grid-column: 1;
  }

  .concept-lead {
    grid-column: 2;
    grid-row: 1 / span 2;
    align-self: end;
  }

  h1,
  .billboard-copy h2 {
    display: grid;
    gap: 10px;
    margin: 12px 0 0;
    font-size: clamp(42px, 6vw, 76px);
    line-height: 0.96;
    font-weight: 580;
  }

  h1 span:last-child,
  .billboard-copy h2 span:last-child {
    color: var(--blue);
    font-size: clamp(22px, 3vw, 42px);
    line-height: 1.18;
    font-weight: 520;
  }

  .concept-lead {
    display: grid;
    gap: 4px;
    margin: 0;
    max-width: 540px;
    color: var(--muted);
    font-size: clamp(16px, 1.7vw, 20px);
    line-height: 1.8;
    overflow-wrap: anywhere;
  }

  .concept-stage {
    position: relative;
    width: 100vw;
    height: clamp(760px, 76vh, 960px);
    min-height: 760px;
    margin-left: calc(50% - 50vw);
    overflow: hidden;
    border-top: 1px solid rgba(38, 64, 104, 0.14);
    border-bottom: 1px solid rgba(38, 64, 104, 0.14);
    background:
      linear-gradient(90deg, rgba(244, 239, 227, 0.86), transparent 18%, transparent 82%, rgba(244, 239, 227, 0.86)),
      linear-gradient(0deg, rgba(244, 239, 227, 0.78), transparent 30%, rgba(244, 239, 227, 0.66));
  }

  .concept-mosaic {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-rows: repeat(3, minmax(0, 1fr));
    gap: clamp(6px, 0.75vw, 10px);
    padding: clamp(8px, 1vw, 16px) 0;
    transform: perspective(1400px) rotateX(0.65deg);
  }

  .concept-mosaic::after {
    content: "";
    position: absolute;
    inset: 0;
