---
import Layout from "../components/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import site from "../data/site.json";
import projects from "../data/projects.json";
import wallpapers from "../data/wallpapers.json";

const featured = projects.filter((project) => project.featured).slice(0, 6);
---

<Layout>
  <section class="hero">
    <div class="container">
      <div class="hero-copy">
        <p class="eyebrow">XUAN Guangzhou Edition 2026</p>
        <h1>{site.brand.nameEn}</h1>
        <p class="tagline">{site.brand.tagline}</p>
        <p class="lead">{site.brand.positioning}</p>
        <div class="button-row">
          <a class="button" href="/projects">查看作品集</a>
          <a class="button secondary" href="/exhibition">展会入口</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container two-col">
      <div>
        <p class="eyebrow">Positioning</p>
        <h2 class="section-title">{site.brand.taglineEn}</h2>
      </div>
      <div>
        <p class="lead">{site.brand.intro}</p>
        <p class="meta">{site.brand.introEn}</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Three Directions</p>
      <h2 class="section-title">从城市到山野，从过去到未来，从数字到现实。</h2>
      <div class="direction-grid">
        {site.directions.map((direction) => (
          <a class="direction" href="/methodology">
            <span>{direction.titleEn}</span>
            <h3>{direction.title}</h3>
            <p>{direction.body}</p>
            <div class="tag-list">
              {direction.keywords.slice(0, 3).map((tag) => <span class="tag">{tag}</span>)}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section method-strip">
    <div class="container two-col">
      <div>
        <p class="eyebrow">Method</p>
        <h2 class="section-title">{site.method.headline}</h2>
        <p class="lead">{site.method.headlineEn}</p>
      </div>
      <ol class="method-list">
        {site.method.steps.map((step) => <li>{step}</li>)}
      </ol>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">Selected Projects</p>
          <h2 class="section-title">代表项目与内容线</h2>
        </div>
        <a class="button secondary" href="/projects">全部项目</a>
      </div>
      <div class="project-grid">
        {featured.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>

  <section class="section wallpaper-strip">
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">Guangzhou Edition Gift</p>
          <h2 class="section-title">展会 4K 壁纸</h2>
        </div>
        <a class="button secondary" href="/downloads">下载壁纸</a>
      </div>
      <div class="wallpaper-grid">
        {wallpapers.map((wallpaper) => (
          <a class="wallpaper" href="/downloads">
            <img src={wallpaper.preview} alt={`${wallpaper.titleCn} wallpaper preview`} loading="lazy" />
            <span>{wallpaper.titleCn}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section final-cta">
    <div class="container two-col">
      <div>
        <p class="eyebrow">Exhibition</p>
        <h2 class="section-title">{site.exhibition.wallText}</h2>
        <p class="lead">{site.exhibition.wallTextEn}</p>
      </div>
      <div class="thin-card">
        <p>{site.exhibition.summary}</p>
        <div class="button-row">
          <a class="button" href="/contact">预约项目沟通</a>
          <a class="button secondary" href="/exhibition">现场页面</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    display: grid;
    align-items: end;
    min-height: 72vh;
    padding: 116px 0 88px;
  }

  h1 {
    margin: 10px 0 18px;
    max-width: 820px;
    font-size: clamp(42px, 5.4vw, 76px);
    line-height: 1.02;
    font-weight: 560;
  }

  .tagline {
    margin: 0 0 22px;
    color: var(--blue);
    font-size: clamp(20px, 2.5vw, 32px);
    line-height: 1.28;
  }

  .direction-grid,
  .project-grid,
  .wallpaper-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
    margin-top: 40px;
  }

  .wallpaper-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-top: 28px;
  }

  .wallpaper {
    position: relative;
    display: block;
    border: 1px solid var(--line);
    border-radius: 8px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.6);
  }

  .wallpaper img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .wallpaper span {
    display: block;
    padding: 10px 12px;
    color: var(--muted);
    font-size: 12px;
  }

  .direction {
    min-height: 360px;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 24px;
    background: rgba(255, 255, 255, 0.55);
  }

  .direction span {
    color: var(--blue);
    font-size: 12px;
  }

  .direction h3 {
    margin: 42px 0 18px;
    font-size: clamp(24px, 2.6vw, 34px);
    line-height: 1.22;
    font-weight: 560;
  }

  .direction p,
  .thin-card p {
    color: var(--muted);
    font-size: 15px;
    line-height: 1.9;
  }

  .method-strip {
    background: rgba(255, 255, 255, 0.38);
  }

  .method-list {
    margin: 0;
    padding: 0;
    list-style: none;
    counter-reset: method;
  }

  .method-list li {
    counter-increment: method;
    display: grid;
    grid-template-columns: 42px 1fr;
    gap: 14px;
    padding: 18px 0;
    border-bottom: 1px solid var(--line);
    font-size: 20px;
    line-height: 1.35;
  }

  .method-list li::before {
    content: counter(method, decimal-leading-zero);
    color: var(--blue);
    font-size: 12px;
  }

  .section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
  }

  @media (max-width: 980px) {
    .direction-grid,
    .project-grid,
    .wallpaper-grid {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
      padding: 48px 0 64px;
    }

    h1 {
      font-size: clamp(38px, 12vw, 54px);
      line-height: 1.04;
    }

    .section-head {
      align-items: start;
      flex-direction: column;
    }
  }
</style>
