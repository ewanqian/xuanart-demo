---
import Layout from "../components/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import site from "../data/site.json";
import projects from "../data/projects.json";
import wallpapers from "../data/wallpapers.json";

const featured = projects.filter((project) => project.featured).slice(0, 6);
const heroSlides = [
  {
    src: "/images/wallpapers/village-nature-field.webp",
    alt: "XUAN Guangzhou visual direction: village and nature field",
  },
  {
    src: "/images/wallpapers/past-future-museum-city.webp",
    alt: "XUAN Guangzhou visual direction: past future museum city",
  },
  {
    src: "/images/wallpapers/urban-glass-island.webp",
    alt: "XUAN Guangzhou visual direction: urban glass island",
  },
];
---

<Layout>
  <section class="hero hero-kv" aria-label="XUAN Spatial Perception brand key visual">
    <div class="hero-slides" aria-hidden="true">
      {heroSlides.map((slide, index) => (
        <figure class="hero-slide" style={`--i:${index}`}>
          <img src={slide.src} alt={slide.alt} loading={index === 0 ? "eager" : "lazy"} />
        </figure>
      ))}
    </div>
    <div class="container hero-inner">
      <div class="hero-copy">
        <p class="eyebrow">XUAN Guangzhou Edition 2026</p>
        <h1>
          <span>{site.brand.nameEn}</span>
          <span>{site.brand.name}</span>
        </h1>
        <p class="tagline">{site.brand.tagline}</p>
        <p class="tagline-en">{site.brand.taglineEn}</p>
        <p class="lead">{site.brand.positioning}</p>
        <div class="button-row">
          <a class="button" href="/projects">Works / 代表项目</a>
          <a class="button secondary" href="/about">About / 关于我们</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container two-col">
      <div>
        <p class="eyebrow">Positioning</p>
        <h2 class="section-title">从真实场所出发</h2>
      </div>
      <div>
        <p class="lead">{site.brand.intro}</p>
        <p class="meta">{site.brand.introEn}</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="eyebrow">Three Directions</p>
      <h2 class="section-title">从城市到山野，从过去到未来，从数字到现实。</h2>
      <div class="direction-grid">
        {site.directions.map((direction) => (
          <a class="direction" href="/methodology">
            <span>{direction.titleEn}</span>
            <h3>{direction.title}</h3>
            <p>{direction.body}</p>
            <div class="tag-list">
              {direction.keywords.slice(0, 3).map((tag) => <span class="tag">{tag}</span>)}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section method-strip">
    <div class="container two-col">
      <div>
        <p class="eyebrow">Method</p>
        <h2 class="section-title">{site.method.headline}</h2>
        <p class="lead">{site.method.headlineEn}</p>
      </div>
      <ol class="method-list">
        {site.method.steps.map((step) => <li>{step}</li>)}
      </ol>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">Selected Projects</p>
          <h2 class="section-title">Works / 代表项目</h2>
        </div>
        <a class="button secondary" href="/projects">查看全部</a>
      </div>
      <div class="project-grid">
        {featured.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>

  <section class="section wallpaper-strip">
    <div class="container">
      <div class="section-head">
        <div>
          <p class="eyebrow">Guangzhou Edition Gift</p>
          <h2 class="section-title">4K 主视觉壁纸</h2>
        </div>
        <a class="button secondary" href="/downloads">下载壁纸</a>
      </div>
      <div class="wallpaper-grid">
        {wallpapers.map((wallpaper) => (
          <a class="wallpaper" href="/downloads">
            <img src={wallpaper.preview} alt={`${wallpaper.titleCn} wallpaper preview`} loading="lazy" />
            <span>{wallpaper.titleCn}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    position: relative;
    min-height: 82vh;
    overflow: hidden;
    border-bottom: 1px solid var(--line);
  }

  .hero-kv {
    display: grid;
    align-items: end;
    padding: 112px 0 72px;
    background:
      linear-gradient(90deg, rgba(251, 250, 245, 0.98) 0%, rgba(251, 250, 245, 0.88) 38%, rgba(251, 250, 245, 0.62) 100%),
      var(--paper);
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 0.72fr);
    gap: 36px;
    align-items: end;
  }

  .hero-slides {
    position: absolute;
    inset: 0;
  }

  .hero-slide {
    position: absolute;
    inset: 0;
    margin: 0;
    opacity: 0;
    animation: heroFade 18s infinite;
    animation-delay: calc(var(--i) * 6s);
  }

  .hero-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: saturate(0.88) contrast(0.96);
  }

  @keyframes heroFade {
    0%,
    100% {
      opacity: 0;
    }

    8%,
    32% {
      opacity: 0.58;
    }
  }

  h1 {
    display: grid;
    gap: 14px;
    margin: 10px 0 24px;
    max-width: 820px;
    font-size: clamp(42px, 5.4vw, 76px);
    line-height: 1.02;
    font-weight: 560;
  }

  h1 span:last-child {
    color: var(--blue);
    font-size: clamp(24px, 3vw, 42px);
    line-height: 1.18;
  }

  .tagline {
    margin: 0 0 8px;
    color: var(--blue);
    font-size: clamp(20px, 2.5vw, 32px);
    line-height: 1.28;
  }

  .tagline-en {
    margin: 0 0 22px;
    color: var(--ink);
    font-size: clamp(18px, 2.1vw, 28px);
    line-height: 1.32;
  }

  .direction-grid,
  .project-grid,
  .wallpaper-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
    margin-top: 40px;
  }

  .wallpaper-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-top: 28px;
  }

  .wallpaper {
    position: relative;
    display: block;
    border: 1px solid var(--line);
    border-radius: 8px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.6);
  }

  .wallpaper img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
  }

  .wallpaper span {
    display: block;
    padding: 10px 12px;
    color: var(--muted);
    font-size: 12px;
  }

  .direction {
    min-height: 360px;
    border: 1px solid var(--line);
    border-radius: 8px;
    padding: 24px;
    background: rgba(255, 255, 255, 0.55);
  }

  .direction span {
    color: var(--blue);
    font-size: 12px;
  }

  .direction h3 {
    margin: 42px 0 18px;
    font-size: clamp(24px, 2.6vw, 34px);
    line-height: 1.22;
    font-weight: 560;
  }

  .direction p,
  .thin-card p {
    color: var(--muted);
    font-size: 15px;
    line-height: 1.9;
  }

  .method-strip {
    background: rgba(255, 255, 255, 0.38);
  }

  .method-list {
    margin: 0;
    padding: 0;
    list-style: none;
    counter-reset: method;
  }

  .method-list li {
    counter-increment: method;
    display: grid;
    grid-template-columns: 42px 1fr;
    gap: 14px;
    padding: 18px 0;
    border-bottom: 1px solid var(--line);
    font-size: 20px;
    line-height: 1.35;
  }

  .method-list li::before {
    content: counter(method, decimal-leading-zero);
    color: var(--blue);
    font-size: 12px;
  }

  .section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 24px;
  }

  @media (max-width: 980px) {
    .direction-grid,
    .project-grid,
    .wallpaper-grid {
      grid-template-columns: 1fr;
    }

    .hero {
      min-height: auto;
      padding: 58px 0 64px;
    }

    .hero-inner {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .hero-kv {
      background:
        linear-gradient(180deg, rgba(251, 250, 245, 0.95) 0%, rgba(251, 250, 245, 0.82) 100%),
        var(--paper);
    }

    h1 {
      font-size: clamp(38px, 12vw, 54px);
      line-height: 1.04;
    }

    .section-head {
      align-items: start;
      flex-direction: column;
    }
  }
</style>
