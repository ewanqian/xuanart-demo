    <div class="container concept-inner">
      <div class="concept-copy">
        <p class="eyebrow">XUAN Spatial Perception</p>
        <h1>
          <span>{site.brand.name}</span>
          <span>让空间重新被感受到</span>
        </h1>
        <p class="concept-lead">空间为画布，光影即颜料。City to Nature / Past to Future / Digital to Real.</p>
      </div>

      <div class="concept-stage">
        <div class="concept-screen" aria-hidden="true">
          {conceptSlides.map((slide, index) => (
            <figure class:list={["concept-slide", { "is-active": index === 0 }]} data-concept-slide data-index={index}>
              <div class="concept-band top-band">
                <img src={slide.top} alt="" loading={index < 2 ? "eager" : "lazy"} />
              </div>
              <div class="concept-band bottom-band">
                <img src={slide.bottom} alt="" loading={index < 2 ? "eager" : "lazy"} />
              </div>
            </figure>
          ))}
        </div>

        <div class="concept-marquee" aria-hidden="true">
          <div>
            <span>空间为画布，光影即颜料</span>
            <span>从城市到山野</span>
            <span>从过去到未来</span>
            <span>从数字到现实</span>
            <span>Let Space Be Felt Again</span>
            <span>空间为画布，光影即颜料</span>
            <span>从城市到山野</span>
            <span>从过去到未来</span>
            <span>从数字到现实</span>
            <span>Let Space Be Felt Again</span>
          </div>
        </div>

        <div class="concept-panel">
          <div class="panel-head">
            <span>曲面屏导览</span>
            <span>TOP + BOTTOM</span>
          </div>
          <div class="concept-copy-stack" aria-live="polite">
            {conceptSlides.map((slide, index) => (
              <article class:list={["concept-item", { "is-active": index === 0 }]} data-concept-copy data-index={index}>
                <p>{slide.subtitle}</p>
                <h2>{slide.title}</h2>
                <span>{slide.label}</span>
                <small>{slide.narration}</small>
              </article>
            ))}
          </div>
          <div class="concept-progress" aria-hidden="true"><span></span></div>
        </div>
      </div>

      <nav class="concept-wall" aria-label="Spatial perception concepts">
        {conceptSlides.map((slide, index) => (
          <button class:list={["concept-thumb", { "is-active": index === 0 }]} type="button" data-concept-cue data-index={index}>
            <img src={slide.top} alt="" loading={index < 4 ? "eager" : "lazy"} />
            <span>{slide.title}</span>
          </button>
        ))}
      </nav>
    </div>
  </section>

  <section class="billboard" data-billboard aria-label="XUAN project media billboard">
    <div class="billboard-stage" aria-hidden="true">
      {billboardSlides.map((slide, index) => (
        <figure class:list={["billboard-slide", { "is-active": index === 0 }]} data-slide data-index={index}>
          {slide.video ? (
            <video
              src={slide.video}
              poster={slide.poster}
              muted
              loop
              playsinline
              preload={index < 2 ? "auto" : "metadata"}
            />
          ) : (
            <img src={slide.poster} alt="" loading={index < 2 ? "eager" : "lazy"} />
          )}
        </figure>
      ))}
    </div>

    <div class="billboard-wash" aria-hidden="true"></div>

    <div class="container billboard-inner">
      <div class="billboard-copy">
        <p class="eyebrow">Tzone / 图域主线</p>
        <h2>
          <span>代表项目</span>
          <span>文旅、展陈、品牌空间</span>
        </h2>
        <p class="billboard-line">以成熟项目呈现空间感知方法。</p>
      </div>

      <div class="billboard-panel">
        <div class="panel-head">
          <span>自动播放</span>
          <span>PV LOOP</span>
        </div>
        <div class="active-copy" aria-live="polite">
          {billboardSlides.map((slide, index) => (
            <article class:list={["active-item", { "is-active": index === 0 }]} data-copy data-index={index}>
              <p>{slide.category}</p>
              <h3>{slide.cue}</h3>
              <span>{slide.title} / {slide.titleEn}</span>
              <small>{slide.line}</small>
            </article>
          ))}
        </div>
        <div class="progress" aria-hidden="true"><span></span></div>
      </div>

      <nav class="cue-rail" aria-label="Loop scenes">
        {billboardSlides.map((slide, index) => (
          <button class:list={["cue-button", { "is-active": index === 0 }]} type="button" data-cue data-index={index}>
            <img src={slide.poster} alt="" loading={index < 4 ? "eager" : "lazy"} />
            <span>{slide.title}</span>
          </button>
        ))}
      </nav>
    </div>
  </section>

  <section class="project-strip" aria-label="Selected project entrances">
    <div class="container">
      <div class="strip-head">
        <p class="eyebrow">Selected Works</p>
        <a class="button secondary" href="/projects">全部项目</a>
      </div>
      <div class="focus-grid">
        {focusWorks.map((work) => (
          <a class="focus-card" href={work.href}>
            <img src={work.poster} alt={`${work.title} preview`} loading="lazy" />
            <div>
              <span>{work.category}</span>
              <h2>{work.title}</h2>
              <p>{work.cue}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<script>
  const setupImageGuide = () => {
    const root = document.querySelector("[data-concept-guide]");
    if (!root) return;
    const slides = Array.from(root.querySelectorAll("[data-concept-slide]"));
    const copies = Array.from(root.querySelectorAll("[data-concept-copy]"));
    const cues = Array.from(root.querySelectorAll("[data-concept-cue]"));
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let active = 0;
    let timer = null;
    const duration = 5600;
    const centerCue = () => {
      const cue = cues[active];
      const rail = cue?.parentElement;
      if (!(cue instanceof HTMLElement) || !(rail instanceof HTMLElement)) return;
      const left = cue.offsetLeft - (rail.clientWidth - cue.clientWidth) / 2;
      rail.scrollTo({ left, behavior: reduceMotion ? "auto" : "smooth" });
    };

    const setActive = (next) => {
      active = (next + slides.length) % slides.length;
      slides.forEach((slide, index) => {
        const isActive = index === active;
        slide.classList.toggle("is-active", isActive);
        copies[index]?.classList.toggle("is-active", isActive);
        cues[index]?.classList.toggle("is-active", isActive);
      });
      centerCue();
    };

    const start = () => {
      if (reduceMotion || timer) return;
      timer = window.setInterval(() => setActive(active + 1), duration);
    };

    cues.forEach((button) => {
      button.addEventListener("click", () => {
        if (timer) {
          window.clearInterval(timer);
          timer = null;
        }
        setActive(Number(button.dataset.index || 0));
        start();
      });
    });

    setActive(0);
    start();
  };

  const setupBillboard = () => {
    const root = document.querySelector("[data-billboard]");
    if (!root) return;
    const slides = Array.from(root.querySelectorAll("[data-slide]"));
    const copies = Array.from(root.querySelectorAll("[data-copy]"));
    const cues = Array.from(root.querySelectorAll("[data-cue]"));
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    let active = 0;
    let timer = null;
    const duration = 5200;

    const setActive = (next) => {
      active = (next + slides.length) % slides.length;
      slides.forEach((slide, index) => {
        const video = slide.querySelector("video");
        const isActive = index === active;
        slide.classList.toggle("is-active", isActive);
        copies[index]?.classList.toggle("is-active", isActive);
        cues[index]?.classList.toggle("is-active", isActive);
        if (!video) return;
        if (isActive && !reduceMotion) {
          video.currentTime = Math.min(video.currentTime, 0.2);
          video.play().catch(() => {});
        } else {
          video.pause();
        }
      });
    };

    const start = () => {
      if (reduceMotion || timer) return;
      timer = window.setInterval(() => setActive(active + 1), duration);
    };

    cues.forEach((button) => {
      button.addEventListener("click", () => {
        if (timer) {
          window.clearInterval(timer);
          timer = null;
        }
        setActive(Number(button.dataset.index || 0));
        start();
      });
    });

    document.addEventListener("visibilitychange", () => {
      if (document.hidden) {
        if (timer) window.clearInterval(timer);
        timer = null;
        slides.forEach((slide) => slide.querySelector("video")?.pause());
      } else {
        setActive(active);
        start();
      }
    });

    setActive(0);
    start();
  };

  setupImageGuide();
  setupBillboard();
</script>

<style>
  .concept-guide {
    position: relative;
    min-height: calc(100svh - 74px);
    overflow: hidden;
    background: #f4efe3;
    color: var(--ink);
    isolation: isolate;
  }

  .concept-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 16% 20%, rgba(255, 240, 105, 0.26), transparent 22rem),
      radial-gradient(circle at 86% 18%, rgba(49, 95, 214, 0.13), transparent 24rem),
      linear-gradient(90deg, rgba(49, 95, 214, 0.05) 1px, transparent 1px) 0 0 / 90px 90px,
      linear-gradient(0deg, rgba(49, 95, 214, 0.035) 1px, transparent 1px) 0 0 / 90px 90px;
  }

  .concept-inner {
    position: relative;
    z-index: 1;
    display: grid;
    min-height: calc(100svh - 74px);
    grid-template-rows: auto 1fr auto;
    gap: 22px;
    padding: 42px 0 28px;
  }

  .concept-copy {
    display: grid;
    grid-template-columns: minmax(260px, 0.75fr) minmax(280px, 0.55fr);
    gap: 32px;
    align-items: end;
  }

  .concept-copy .eyebrow,
  .concept-copy h1 {
    grid-column: 1;
  }

  .concept-lead {
    grid-column: 2;
    grid-row: 1 / span 2;
    align-self: end;
  }

  h1,
  .billboard-copy h2 {
    display: grid;
    gap: 10px;
    margin: 12px 0 0;
    font-size: clamp(42px, 6vw, 76px);
    line-height: 0.96;
    font-weight: 580;
  }

  h1 span:last-child,
  .billboard-copy h2 span:last-child {
    color: var(--blue);
    font-size: clamp(22px, 3vw, 42px);
    line-height: 1.18;
    font-weight: 520;
  }

  .concept-lead {
    margin: 0;
    max-width: 540px;
    color: var(--muted);
    font-size: clamp(16px, 1.7vw, 20px);
    line-height: 1.8;
  }

  .concept-stage {
    position: relative;
    width: 100vw;
    min-height: clamp(560px, 68vh, 860px);
    margin-left: calc(50% - 50vw);
  }

  .concept-screen {
    position: absolute;
    inset: 0;
    overflow: hidden;
    border-top: 1px solid rgba(38, 64, 104, 0.14);
    border-bottom: 1px solid rgba(38, 64, 104, 0.14);
    background: rgba(255, 255, 255, 0.32);
    box-shadow: 0 30px 100px rgba(81, 68, 41, 0.14);
    transform: perspective(1400px) rotateX(0.8deg);
  }

  .concept-screen::before {
    content: "";
    position: absolute;
    inset: 0 4%;
    z-index: 2;
    border-top: 1px solid rgba(255, 255, 255, 0.74);
    border-bottom: 1px solid rgba(255, 255, 255, 0.54);
    border-radius: 50% / 9%;
    opacity: 0.78;
    pointer-events: none;
  }

  .concept-screen::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(244, 239, 227, 0.9), rgba(244, 239, 227, 0.18) 28%, rgba(244, 239, 227, 0.16) 70%, rgba(244, 239, 227, 0.88)),
      linear-gradient(0deg, rgba(244, 239, 227, 0.72), transparent 34%, rgba(244, 239, 227, 0.3));
    pointer-events: none;
  }

  .concept-panel {
    position: absolute;
    right: max(24px, calc((100vw - var(--max)) / 2));
    bottom: 58px;
    width: min(360px, calc(100% - 48px));
    z-index: 2;
  }

  .concept-marquee {
    position: absolute;
    top: 22px;
    left: 0;
    right: 0;
    z-index: 2;
    overflow: hidden;
    pointer-events: none;
  }

  .concept-marquee div {
    display: flex;
    width: max-content;
    min-width: 200%;
    gap: 34px;
    animation: conceptTextDrift 30s linear infinite;
  }

  .concept-marquee span {
    color: rgba(23, 29, 38, 0.74);
    font-size: clamp(13px, 1.2vw, 17px);
    line-height: 1;
    white-space: nowrap;
  }

  @keyframes conceptTextDrift {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  .concept-slide {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-rows: 1fr 1fr;
    gap: 0;
    margin: 0;
    opacity: 0;
    transform: scale(1.02);
    transition:
      opacity 780ms ease,
      transform 1400ms cubic-bezier(0.18, 0.84, 0.22, 1);
  }

  .concept-slide.is-active {
    opacity: 1;
    transform: scale(1);
  }

  .concept-band {
    position: relative;
    overflow: hidden;
  }

  .concept-band::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(0, 0, 0, 0.16), transparent 24%, transparent 76%, rgba(0, 0, 0, 0.2)),
      linear-gradient(0deg, rgba(255, 255, 255, 0.08), transparent 34%, rgba(255, 255, 255, 0.08));
    pointer-events: none;
  }

  .concept-band img {
    width: 122%;
    height: 100%;
    object-fit: cover;
    max-width: none;
    transform: translateX(-14%);
  }

  .concept-slide.is-active .concept-band img {
    animation: conceptPan 7.2s ease-in-out infinite alternate;
  }

  .bottom-band img {
    animation-delay: 450ms;
  }

  @keyframes conceptPan {
    from {
      transform: translateX(-14%) scale(1.01);
    }
    to {
      transform: translateX(-2%) scale(1.03);
    }
  }

  .concept-panel,
  .billboard-panel {
    border: 1px solid rgba(38, 64, 104, 0.16);
