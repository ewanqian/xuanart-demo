---
import Layout from "../components/Layout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import projects from "../data/projects.json";

const categories = [...new Set(projects.map((project) => project.category))];
---

<Layout title="项目 | XUAN Spatial Perception">
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">Projects</p>
      <h1>项目与内容线</h1>
      <p class="lead">图域空间项目、Virtura 内容线，以及正在整理的 XR / Vision Pro / 空间计算 Demo。</p>
    </div>
  </section>

  {categories.map((category) => (
    <section class="section" id={category.toLowerCase().replaceAll(" ", "-").replaceAll("/", "")}>
      <div class="container">
        <div class="category-head">
          <p class="eyebrow">{category}</p>
          <span>{projects.filter((project) => project.category === category).length} entries</span>
        </div>
        <div class="project-grid">
          {projects
            .filter((project) => project.category === category)
            .map((project) => <ProjectCard project={project} compact />)}
        </div>
      </div>
    </section>
  ))}
</Layout>

<style>
  .page-hero {
    padding: 94px 0 58px;
  }

  h1 {
    max-width: 980px;
    margin: 12px 0 20px;
    font-size: clamp(34px, 6.5vw, 78px);
    line-height: 1.08;
    font-weight: 560;
  }

  .category-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    border-bottom: 1px solid var(--line);
    padding-bottom: 14px;
  }

  .category-head span {
    color: var(--muted);
    font-size: 12px;
  }

  .project-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
    margin-top: 24px;
  }

  @media (max-width: 980px) {
    .project-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
